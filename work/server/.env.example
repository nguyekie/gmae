# Sao chép file này thành .env và điền giá trị thật

# Chuỗi kết nối PostgreSQL (Railway/Render/Neon/Supabase đều cấp sẵn khi tạo DB)
DATABASE_URL=postgres://user:password@host:5432/etheria

# Chuỗi bí mật để ký JWT — đổi thành chuỗi ngẫu nhiên dài khi deploy thật
JWT_SECRET=change_this_to_a_long_random_string

# Cổng chạy server
PORT=4000

# Domain frontend (Netlify) được phép gọi API — dùng cho CORS
CLIENT_ORIGIN=http://localhost:5173
